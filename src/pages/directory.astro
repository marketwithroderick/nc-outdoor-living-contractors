---
import { readFile } from 'fs/promises';
import type { AstroComponentFactory } from 'astro';
import Layout from '../layouts/Layout.astro';
import ContractorCard from '../components/ContractorCard.astro';

interface Contractor {
  id: string;
  name: string;
  location: string;
  region: string;
  services: string[];
  phone: string;
  email: string;
  website: string;
  rating: number;
  reviews: number;
  description: string;
}

let contractors: Contractor[] = [];

// Load static JSON at build time
const dataPath = new URL('../data/contractors.json', import.meta.url);
const raw = await readFile(dataPath, 'utf-8');
contractors = JSON.parse(raw);
---
<Layout title="NC Outdoor Living Contractors Directory">
  <section class="max-w-6xl mx-auto py-12 px-6">
    <h1 class="text-4xl font-bold mb-6">North Carolina Outdoor Living Contractors</h1>
    <p class="text-lg text-gray-700 mb-8">Find trusted contractors for decks, patios, pergolas, landscaping, and more across the state.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {contractors.map(contractor => (
        <ContractorCard contractor={contractor} />
      ))}
    </div>
  </section>
</Layout>