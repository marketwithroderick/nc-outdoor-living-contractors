---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Outdoor Living Contractors | Marketing, Finance & Operations">
  <!-- Navigation -->
  <nav class="bg-stone-900 text-white py-4">
    <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
      <span class="text-xl font-bold">Outdoor Living Contractors</span>
      <div class="space-x-6 hidden md:block">
        <a href="#services" class="hover:text-emerald-400 transition">Services</a>
        <a href="#about" class="hover:text-emerald-400 transition">About</a>
        <a href="#contact" class="hover:text-emerald-400 transition">Contact</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-stone-800 to-stone-900 text-white py-24">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        Build Your Outdoor Living Business
      </h1>
      <p class="text-xl text-stone-300 mb-8 max-w-2xl">
        We specialize in marketing, finance, and operations for contractors 
        in decks, patios, pergolas, and landscaping.
      </p>
      <a href="/directory" class="inline-block bg-emerald-600 hover:bg-emerald-500 text-white px-8 py-4 rounded-lg font-semibold transition">
        Browse Directory
      </a>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center mb-16">Our Services</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Marketing -->
        <div class="bg-white p-8 rounded-xl shadow-lg border-t-4 border-emerald-500">
          <div class="text-4xl mb-4">📣</div>
          <h3 class="text-2xl font-bold mb-4">Marketing</h3>
          <ul class="space-y-2 text-stone-600">
            <li>• Lead generation strategies</li>
            <li>• Website design & SEO</li>
            <li>• Social media management</li>
            <li>• Brand development</li>
          </ul>
        </div>

        <!-- Finance -->
        <div class="bg-white p-8 rounded-xl shadow-lg border-t-4 border-emerald-500">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="text-2xl font-bold mb-4">Finance</h3>
          <ul class="space-y-2 text-stone-600">
            <li>• Financial planning</li>
            <li>• Cash flow management</li>
            <li>• Budget optimization</li>
            <li>• Profitability analysis</li>
          </ul>
        </div>

        <!-- Operations -->
        <div class="bg-white p-8 rounded-xl shadow-lg border-t-4 border-emerald-500">
          <div class="text-4xl mb-4">⚙️</div>
          <h3 class="text-2xl font-bold mb-4">Operations</h3>
          <ul class="space-y-2 text-stone-600">
            <li>• Project management</li>
            <li>• Workflow automation</li>
            <li>• Team coordination</li>
            <li>• Supply chain optimization</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="bg-stone-100 py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center mb-16">Why Choose Us</h2>
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-lg text-stone-600 mb-6">
            We're a specialized consulting firm dedicated to helping outdoor living 
            contractors grow their businesses. Whether you're just starting out or 
            looking to scale, we bring expertise in the areas that matter most.
          </p>
          <p class="text-lg text-stone-600 mb-6">
            Our team understands the unique challenges of the outdoor living industry—
            from seasonal demand to material sourcing and client expectations.
          </p>
          <ul class="space-y-3">
            <li class="flex items-center gap-3">
              <span class="text-emerald-600 text-xl">✓</span>
              <span>Industry-specific expertise</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-emerald-600 text-xl">✓</span>
              <span>End-to-end business solutions</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="text-emerald-600 text-xl">✓</span>
              <span>Proven results for contractors</span>
            </li>
          </ul>
        </div>
        <div class="bg-stone-200 rounded-xl h-80 flex items-center justify-center">
          <span class="text-stone-500 text-lg">[Outdoor Project Image]</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-4xl font-bold text-center mb-8">Let's Grow Your Business</h2>
      <p class="text-lg text-stone-600 text-center mb-12">
        Ready to take your outdoor living contractor business to the next level? 
        Get in touch today for a free consultation.
      </p>
      <form class="bg-white p-8 rounded-xl shadow-lg space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium mb-2">Name</label>
            <input type="text" class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="Your name" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Email</label>
            <input type="email" class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="your@email.com" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Phone</label>
          <input type="tel" class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="(555) 123-4567" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Message</label>
          <textarea rows="4" class="w-full px-4 py-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-transparent" placeholder="Tell us about your business..."></textarea>
        </div>
        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-4 rounded-lg font-semibold transition">
          Send Message
        </button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-stone-900 text-stone-400 py-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="mb-6 md:mb-0">
          <span class="text-white text-xl font-bold">Outdoor Living Contractors</span>
          <p class="mt-2">Marketing • Finance • Operations</p>
        </div>
        <div class="text-center md:text-right">
          <p>© 2026 Outdoor Living Contractors. All rights reserved.</p>
        </div>
      </div>
    </div>
  </footer>
</Layout>