---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html class="light" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="The Carolinian Heritage - Connecting Carolina's finest outdoor living contractors with homeowners" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700;6..72,800&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "tertiary-container": "#663500",
              "surface": "#f8faf5",
              "on-background": "#191c1a",
              "on-error-container": "#93000a",
              "on-error": "#ffffff",
              "inverse-surface": "#2e312e",
              "outline": "#727973",
              "primary-fixed-dim": "#b0cdbb",
              "on-secondary-fixed-variant": "#3d484f",
              "surface-container": "#edeeea",
              "background": "#f8faf5",
              "on-tertiary": "#ffffff",
              "on-tertiary-fixed": "#2f1500",
              "on-surface": "#191c1a",
              "surface-variant": "#e1e3df",
              "on-tertiary-fixed-variant": "#6e3900",
              "secondary-container": "#d6e1e9",
              "on-primary-fixed-variant": "#324c3e",
              "surface-container-lowest": "#ffffff",
              "error": "#ba1a1a",
              "on-primary-container": "#98b5a3",
              "secondary": "#556067",
              "surface-bright": "#f8faf5",
              "inverse-on-surface": "#f0f1ed",
              "on-surface-variant": "#424844",
              "on-tertiary-container": "#fe942c",
              "surface-container-highest": "#e1e3df",
              "on-secondary": "#ffffff",
              "inverse-primary": "#b0cdbb",
              "on-primary": "#ffffff",
              "surface-tint": "#496455",
              "error-container": "#ffdad6",
              "surface-container-low": "#f2f4f0",
              "surface-dim": "#d9dbd6",
              "on-primary-fixed": "#062014",
              "primary-fixed": "#ccead6",
              "tertiary-fixed": "#ffdcc3",
              "tertiary-fixed-dim": "#ffb77d",
              "primary-container": "#2d4739",
              "surface-container-high": "#e7e9e4",
              "secondary-fixed": "#d9e4ec",
              "primary": "#173124",
              "outline-variant": "#c2c8c2",
              "on-secondary-container": "#59646b",
              "tertiary": "#462200",
              "secondary-fixed-dim": "#bdc8d0",
              "on-secondary-fixed": "#121d23"
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg: "0.25rem",
              xl: "0.5rem",
              full: "0.75rem"
            },
            fontFamily: {
              headline: ["Newsreader"],
              body: ["Manrope"],
              label: ["Manrope"]
            }
          },
        },
      }
    </script>
    <title>{title}</title>
  </head>
  <body class="bg-surface text-on-surface font-body selection:bg-primary-fixed selection:text-on-primary-fixed">
    <slot />
  </body>
</html>

<style is:global>
  .material-symbols-outlined {
    font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24
  }
  .editorial-shadow {
    box-shadow: 0 12px 40px rgba(25, 28, 26, 0.06)
  }
</style>